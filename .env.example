# ┌──────────────────────────────────────────────────────────────────┐
# │  K.R.I.A. v2.0 – Environment Configuration                     │
# │  Copy to .env and adjust values for your setup.                 │
# │  All variables are prefixed KRIA_ automatically.                │
# └──────────────────────────────────────────────────────────────────┘

# ── Service URLs ──────────────────────────────────────────────────
KRIA_LLAMA_API_URL=http://localhost:8080
KRIA_WHISPER_API_URL=http://localhost:8081
KRIA_PIPER_API_URL=http://localhost:8082
KRIA_REDIS_URL=redis://localhost:6379/0
KRIA_CHROMA_URL=http://localhost:8083
KRIA_BRIDGE_URL=http://localhost:9000

# ── Bridge Authentication ─────────────────────────────────────────
# Set one of these (file takes precedence in Docker)
KRIA_BRIDGE_SECRET=
KRIA_BRIDGE_SECRET_FILE=

# ── ChromaDB ──────────────────────────────────────────────────────
KRIA_CHROMADB_HOST=localhost
KRIA_CHROMADB_PORT=8083
KRIA_CHROMADB_PATH=./data/chroma

# ── Storage Paths ─────────────────────────────────────────────────
KRIA_SQLITE_PATH=./data/kria.db
KRIA_ROLLBACK_DIR=~/.kria/rollback
KRIA_AUDIT_LOG_PATH=./data/audit.db
KRIA_LOG_DIR=./data/logs
KRIA_PLUGINS_DIR=~/.kria/plugins
KRIA_WORKFLOWS_DIR=~/.kria/workflows
KRIA_SNIPPETS_DIR=~/.kria/snippets
KRIA_DOWNLOADS_DIR=~/Downloads/kria
KRIA_KNOWLEDGE_DIR=~/.kria/knowledge

# ── Safety ────────────────────────────────────────────────────────
KRIA_DEFAULT_RISK_LEVEL=RED
KRIA_EMERGENCY_MODE=false
KRIA_SAFETY_DEMO_MODE=false

# ── Limits & Tuning ──────────────────────────────────────────────
KRIA_MAX_CONTEXT_TURNS=20
KRIA_TOOL_TIMEOUT_SECONDS=30.0
KRIA_HITL_TIMEOUT_SECONDS=30.0
KRIA_ROLLBACK_RETENTION_HOURS=72
KRIA_ROLLBACK_MAX_SIZE_GB=5.0
KRIA_REDIS_CACHE_TTL_SECONDS=60
KRIA_MAX_CONCURRENT_TOOLS=3

# ── Internet ──────────────────────────────────────────────────────
KRIA_INTERNET_ENABLED=true
KRIA_INTERNET_HTTPS_ONLY=true
KRIA_INTERNET_MAX_RESPONSE_MB=50
KRIA_INTERNET_RATE_LIMIT_PER_MIN=60
KRIA_INTERNET_SEARCH_CACHE_TTL=3600
KRIA_INTERNET_PAGE_CACHE_TTL=86400
KRIA_MAX_DOWNLOAD_SIZE_MB=500

# ── Voice / Wake Word ────────────────────────────────────────────
KRIA_VOICE_ENABLED=true
KRIA_WAKE_WORD=hey kria
KRIA_WAKE_ENERGY_THRESHOLD=500.0
KRIA_VAD_SILENCE_MS=1000
# Optional: Picovoice Porcupine API key for hardware wake-word engine.
# Leave blank to use the built-in openwakeword model (no key required).
KRIA_PORCUPINE_ACCESS_KEY=

# ── Language ──────────────────────────────────────────────────────
KRIA_LANGUAGE=en
KRIA_LANGUAGE_AUTO_DETECT=false

# ── Automation ────────────────────────────────────────────────────
KRIA_AUTOMATION_ENABLED=true
KRIA_MAX_SCHEDULED_TASKS=50
KRIA_MAX_WORKFLOWS=20

# ── Plugins ───────────────────────────────────────────────────────
KRIA_PLUGINS_ENABLED=true

# ── Notifications ─────────────────────────────────────────────────
KRIA_NOTIFICATIONS_ENABLED=true

# ── Telegram (optional) ──────────────────────────────────────────
KRIA_TELEGRAM_ENABLED=false
KRIA_TELEGRAM_BOT_TOKEN=
KRIA_TELEGRAM_ALLOWED_CHAT_IDS=[]

# ── Web UI ────────────────────────────────────────────────────────
# Partial mic label to prefer in web UI (blank = browser default)
KRIA_MIC_DEVICE_LABEL=

{
  "name": "kria-e2e",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:tauri-mock": "KRIA_E2E_START_UI=1 KRIA_UI_URL=http://127.0.0.1:1420 playwright test --project=e2e-tauri-mock",
    "test:tauri-mock:headed": "KRIA_E2E_START_UI=1 KRIA_UI_URL=http://127.0.0.1:1420 playwright test --project=e2e-tauri-mock --headed",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "typescript": "^5.7.0",
    "ws": "^8.18.0",
    "@types/ws": "^8.5.13"
  }
}

{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "KRIA",
  "version": "0.1.0",
  "identifier": "com.kria.desktop",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "fuser -k 1420/tcp 2>/dev/null; if [ -f ui/package.json ]; then npm run dev --prefix ui; elif [ -f ../ui/package.json ]; then npm run dev --prefix ../ui; else npm run dev --prefix ../../ui; fi",
    "beforeBuildCommand": "if [ -f ui/package.json ]; then npm run build --prefix ui; elif [ -f ../ui/package.json ]; then npm run build --prefix ../ui; else npm run build --prefix ../../ui; fi"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "K.R.I.A.",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../config/default.toml",
      "../../config/mcp_servers.json",
      "../../models/piper/en_US-ryan-high.onnx",
      "../../models/piper/en_US-ryan-high.onnx.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [],
        "desktopTemplate": null,
        "section": "utils"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}

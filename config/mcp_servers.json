{
  "servers": [
    {
      "name": "fs",
      "transport": "stdio",
      "command": "mcp-server-filesystem",
      "args": ["/home", "/media", "/tmp"],
      "enabled": true,
      "trust_level": "YELLOW",
      "tool_overrides": {
        "move_file": "RED",
        "write_file": "YELLOW",
        "edit_file": "YELLOW"
      }
    },
    {
      "name": "gworkspace",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "google-workspace-mcp", "serve"],
      "env": {
        "GOOGLE_MCP_CONFIG_DIR": "/home/obaid/.google-mcp"
      },
      "enabled": true,
      "trust_level": "YELLOW",
      "tool_overrides": {
        "createGmailDraft": "YELLOW",
        "sendGmailDraft": "YELLOW",
        "deleteGmailMessage": "RED",
        "deleteFile": "RED",
        "createCalendarEvent": "YELLOW",
        "deleteCalendarEvent": "RED"
      }
    },
    {
      "name": "colab-mcp",
      "transport": "stdio",
      "command": "uvx",
      "args": ["git+https://github.com/googlecolab/colab-mcp"],
      "enabled": true,
      "trust_level": "YELLOW",
      "tool_overrides": {}
    }
  ]
}
